{
    "name": "gps-dozor-ghost-run-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run start:dev --workspace=server\" \"npm run dev --workspace=client\"",
        "build": "npm run build --workspace=client && npm run build --workspace=server",
        "install:all": "npm install && npm install --workspace=client && npm install --workspace=server"
    },
    "devDependencies": {
        "@types/geojson": "^7946.0.16",
        "@types/mapbox__point-geometry": "^1.0.87",
        "@types/mapbox-gl": "^3.4.1",
        "concurrently": "^8.2.2"
    }
}
