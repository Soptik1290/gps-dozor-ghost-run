// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// NOTE: Prisma v7 — datasource URL is set in prisma.config.ts, not here.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────
enum Role {
  ADMIN
  DRIVER
}

enum VehicleStatus {
  ACTIVE
  SERVICE
  RETIRED
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(DRIVER)
  createdAt DateTime @default(now())

  driverTrips Trip[] @relation("DriverTrips")

  @@index([username])
}

// ─────────────────────────────────────────────
// Vehicle
// ─────────────────────────────────────────────
model Vehicle {
  id         Int           @id @default(autoincrement())
  name       String
  plate      String        @unique
  status     VehicleStatus @default(ACTIVE)
  groupCode  String        @default("FLEET")
  createdAt  DateTime      @default(now())

  trips Trip[]
}

// ─────────────────────────────────────────────
// Trip
// ─────────────────────────────────────────────
model Trip {
  id               Int      @id @default(autoincrement())
  vehicleId        Int
  driverId         Int?
  startTime        DateTime
  endTime          DateTime
  distanceKm       Float    @default(0)
  fuelConsumption  Float    @default(0)
  avgSpeed         Float    @default(0)

  // Gamification Fields
  score            Int      @default(0)
  rank             String   @default("F")
  ecoEventsCount   Int      @default(0)

  createdAt        DateTime @default(now())

  vehicle Vehicle  @relation(fields: [vehicleId], references: [id])
  driver  User?    @relation("DriverTrips", fields: [driverId], references: [id])
  logs    TripLog[]

  @@index([vehicleId])
  @@index([driverId])
}

// ─────────────────────────────────────────────
// TripLog (Dense GPS breadcrumbs for Replay)
// ─────────────────────────────────────────────
model TripLog {
  id        Int      @id @default(autoincrement())
  tripId    Int
  lat       Float
  lng       Float
  speed     Float    @default(0)
  timestamp DateTime

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([timestamp])
}
