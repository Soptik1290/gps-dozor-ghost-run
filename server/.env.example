# GPS Dozor: Ghost Run — Server .env.example
# Copy this to .env and fill in the values

# PostgreSQL connection string
# For local dev (Docker or local Postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gpsdozor?schema=public"

# For Neon.tech (cloud, swap for Render deployment):
# DATABASE_URL="postgresql://user:pass@ep-xyz-123.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# JWT Authentication
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# GPS Dozor API Integration
GPS_DOZOR_URL="https://a1.gpsguard.eu/api/v1"
GPS_DOZOR_USERNAME="api_gpsdozor"
GPS_DOZOR_PASSWORD="yakmwlARdn"

# OpenAI (optional - for AI feedback feature)
OPENAI_API_KEY="sk-..."

# Server Port
PORT=3000
